{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crucible Studio",
  "version": "0.2.0",
  "identifier": "sh.crucible.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Crucible Studio",
        "width": 1120,
        "height": 780,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
