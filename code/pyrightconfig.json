{
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.11",
  "include": [
    "packages",
    "apps",
    "bench",
    "tests"
  ],
  "exclude": [
    "**/__pycache__",
    "**/.venv",
    "packages/crucible-engine/src/crucible_engine/llama_backend.py"
  ],
  "typeCheckingMode": "basic",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "strict": [
    "packages/crucible-engine/src",
    "packages/crucible-grammar/src",
    "packages/crucible-gate/src"
  ]
}
